#!/usr/bin/env bash

set -euo pipefail

TOOL_NAME="aws-iam-authenticator"
GH_REPO="https://github.com/kubernetes-sigs/aws-iam-authenticator"

fail() {
  echo -e "asdf-$TOOL_NAME: $*" >&2
  exit 1
}

get_platform() {
  local arch
  arch="$(uname -m | sed 's/aarch64/arm64/g; s/x86_64/amd64/g')"
  echo "$(uname | tr '[:upper:]' '[:lower:]')_${arch}"
}

get_download_url() {
  local version="$1" filename="$2"
  local -r exists="curl --output /dev/null --silent --fail --head"

  # Release tags switched from an unprefixed (0.5.x) to a "v"-prefixed (v0.6.0+)
  # naming over time, so probe both.
  if $exists "$GH_REPO/releases/download/${version}/${filename}"; then
    echo "$GH_REPO/releases/download/${version}/${filename}"
  elif $exists "$GH_REPO/releases/download/v${version}/${filename}"; then
    echo "$GH_REPO/releases/download/v${version}/${filename}"
  else
    fail "could not find release asset ${filename} for version ${version}"
  fi
}

version="$ASDF_INSTALL_VERSION"
platform="$(get_platform)"
filename="${TOOL_NAME}_${version}_${platform}"
url="$(get_download_url "$version" "$filename")"

echo "* Downloading $TOOL_NAME release $version from $url..."
mkdir -p "$ASDF_DOWNLOAD_PATH"
curl -fsSL -o "$ASDF_DOWNLOAD_PATH/$TOOL_NAME" "$url" || fail "could not download $url"
