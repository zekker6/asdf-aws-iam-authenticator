#!/usr/bin/env bash

set -euo pipefail

TOOL_NAME="aws-iam-authenticator"

fail() {
  echo -e "asdf-$TOOL_NAME: $*" >&2
  exit 1
}

install_version() {
  local install_path="$1"
  local bin_install_path="$install_path/bin"
  local binary_path="$bin_install_path/$TOOL_NAME"

  [ -f "$ASDF_DOWNLOAD_PATH/$TOOL_NAME" ] || fail "downloaded binary not found in $ASDF_DOWNLOAD_PATH"

  mkdir -p "$bin_install_path"
  cp "$ASDF_DOWNLOAD_PATH/$TOOL_NAME" "$binary_path"
  chmod +x "$binary_path"

  echo "$TOOL_NAME $ASDF_INSTALL_VERSION installation was successful!"
}

install_version "$ASDF_INSTALL_PATH"
